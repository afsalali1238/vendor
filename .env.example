# ================================================================
# KASPER VENDOR OS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is in .gitignore.
# ================================================================

# ── SUPABASE (required for all functionality) ────────────────────
# Get from: supabase.co → your project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...your_anon_key_here

# ── EMAIL — Resend (free tier: 3,000 emails/month) ───────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_...your_resend_key_here
FROM_EMAIL=noreply@kasperlogistics.vercel.app

# ── WHATSAPP — 360dialog (Phase 2, AED 50/month) ─────────────────
# Get from: 360dialog.com after Meta business verification
# Phase 1: leave blank — wa.me deep links are used instead
DIALOG_360_KEY=
DIALOG_360_PARTNER_TOKEN=

# ── PAYMENTS — Telr UAE ───────────────────────────────────────────
# Get from: telr.com → your merchant account
# Phase 1: use example links for demo. Fill in for live payments.
TELR_STORE_ID=
TELR_AUTH_KEY=
TELR_TEST_MODE=true

# ── APP CONFIG ───────────────────────────────────────────────────
APP_URL=https://vendor.kasperlogistics.vercel.app
KASPER_ADMIN_PHONE=+971500000000

# ── DRIVER TOKEN SECRET ──────────────────────────────────────────
# Used by Edge Function to sign/verify driver WhatsApp link tokens.
# Generate: openssl rand -base64 32
DRIVER_TOKEN_SECRET=your_32_char_random_secret_here
